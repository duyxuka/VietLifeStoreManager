<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath=".\VietlifeStore.Web.exe" arguments=".\VietlifeStore.Web.dll" stdoutLogEnabled="true" stdoutLogFile=".\Logs\stdout" hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
          <environmentVariable name="ASPNETCORE_URLS" value="https://mayhutsua.com.vn" />
        </environmentVariables>
      </aspNetCore>
      <!-- Xóa header mặc định -->
      <httpProtocol>
        <customHeaders>
          <remove name="X-Powered-By" />
          <add name="X-Forwarded-Proto" value="https" />
        </customHeaders>
      </httpProtocol>

      <!-- ============================= -->
      <!-- 🔁 URL Rewrite Configuration -->
      <!-- ============================= -->
      <rewrite>
        <rules>
          <clear />

          <!-- Không rewrite file tĩnh -->
          <rule name="Static Files" stopProcessing="true">
            <match url="([\S]+[.](jpg|jpeg|gif|css|png|js|mjs|json|wasm|ico|html|map|svg|woff|woff2|ttf|eot|otf))" />
            <action type="None" />
          </rule>

          <!-- Không rewrite các API endpoint -->
          <rule name="Backend APIs" stopProcessing="true">
            <match url=".*" />
            <conditions logicalGrouping="MatchAny">
              <add input="{REQUEST_URI}" pattern="^/(api|swagger|health-status|health-ui|health-ui-api|signalr|\.well-known|connect|Account|AbpApplicationConfiguration)" />
            </conditions>
            <action type="None" />
          </rule>
        </rules>
      </rewrite>

      <!-- ============================= -->
      <!-- ⚙️ Security -->
      <!-- ============================= -->
      <security>
        <requestFiltering allowDoubleEscaping="true" />
      </security>

      <!-- ============================= -->
      <!-- 🧩 Static Content / MIME Types -->
      <!-- ============================= -->
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" />
        <!-- Remove trùng -->
        <remove fileExtension=".svg" />
        <remove fileExtension=".eot" />
        <remove fileExtension=".ttf" />
        <remove fileExtension=".woff" />
        <remove fileExtension=".woff2" />
        <remove fileExtension=".otf" />
        <remove fileExtension=".js" />
        <remove fileExtension=".mjs" />
        <remove fileExtension=".json" />
        <!-- ⚠️ Thêm dòng này -->
        <remove fileExtension=".wasm" />

        <!-- Thêm lại MIME cần thiết -->
        <mimeMap fileExtension=".ttf" mimeType="application/octet-stream" />
        <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
        <mimeMap fileExtension=".eot" mimeType="application/vnd.ms-fontobject" />
        <mimeMap fileExtension=".woff" mimeType="application/x-woff" />
        <mimeMap fileExtension=".woff2" mimeType="application/x-woff" />
        <mimeMap fileExtension=".otf" mimeType="application/otf" />
        <mimeMap fileExtension=".js" mimeType="application/javascript" />
        <mimeMap fileExtension=".mjs" mimeType="application/javascript" />
        <mimeMap fileExtension=".json" mimeType="application/json" />
        <mimeMap fileExtension=".wasm" mimeType="application/wasm" />
      </staticContent>

      <!-- ============================= -->
      <!-- 📄 Default Document -->
      <!-- ============================= -->
      <defaultDocument>
        <files>
          <clear />
          <add value="index.html" />
        </files>
      </defaultDocument>
      
    </system.webServer>
  </location>
</configuration>
